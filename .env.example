# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google Cloud Service Account (for GA4 + Search Console)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account-key.json

# Google Ads (OAuth2) - run setup_google_ads_auth.py to get these
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=102-851-7956

# Google Analytics GA4
GA4_PROPERTY_ID=your-ga4-property-id

# Google Search Console
SEARCH_CONSOLE_SITE_URL=sc-domain:sourcy.ai

# SEMrush
SEMRUSH_API_KEY=your-semrush-api-key

# GEO/AEO Visibility APIs (optional — tools degrade gracefully if missing)
SERPAPI_KEY=your-serpapi-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# Meta Ads (Facebook Business) — for deep ad recommendation diagnostics
META_ACCESS_TOKEN=your-meta-system-user-token
META_AD_ACCOUNT_ID=your-ad-account-id
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
