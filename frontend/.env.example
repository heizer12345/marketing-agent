# Copy to Vercel → Project → Settings → Environment Variables (Production + Preview)
# Required for Vercel deploy — set BEFORE redeploy so Next.js rewrites point at your API.

# HTTPS URL of your Railway/Render Python backend (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=https://your-app.up.railway.app

# WebSocket URL for Chat (same host, wss://)
NEXT_PUBLIC_BACKEND_WS_URL=wss://your-app.up.railway.app
