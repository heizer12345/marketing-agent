# Render / Vercel → Environment Variables, then Redeploy
# Use your Railway public domain (Settings → Networking → Generate Domain)

NEXT_PUBLIC_BACKEND_URL=https://your-app.up.railway.app
NEXT_PUBLIC_BACKEND_WS_URL=wss://your-app.up.railway.app

# Optional server-only alias (runtime API proxy reads this too)
# BACKEND_URL=https://your-app.up.railway.app

# Test wiring after deploy: https://YOUR-VERCEL-URL/api/diagnostic
